{
  "name": "n8n-nodes-pancakeswap",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for PancakeSwap DEX providing 27 resources and 300+ operations for swapping, liquidity, farming, staking, IFOs, lottery, predictions, perpetuals, and cross-chain bridging. Supports V2, V3, and StableSwap pools across multiple chains.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-pancakeswap.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-pancakeswap#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-pancakeswap/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "pancakeswap",
    "defi",
    "dex",
    "decentralized-exchange",
    "swap",
    "liquidity",
    "farming",
    "staking",
    "cake",
    "bsc",
    "bnb-chain",
    "ethereum",
    "arbitrum",
    "base",
    "zksync",
    "linea",
    "perpetuals",
    "ifo",
    "lottery",
    "prediction",
    "nft",
    "blockchain",
    "web3",
    "cryptocurrency"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PancakeSwapNetwork.credentials.js",
      "dist/credentials/PancakeSwapApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PancakeSwap/PancakeSwap.node.js",
      "dist/nodes/PancakeSwap/PancakeSwapTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "ethers": "^6.11.1",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "bignumber.js": "^9.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.30.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
